# LangSmith tracing (optional — observability for the LLM classifier)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT="seeker"

# OpenRouter (LLM threat classifier, PRD 5.4 / §8)
OPENROUTER_API_KEY=<your-openrouter-api-key>
# Model slug; defaults to anthropic/claude-3.5-sonnet when empty.
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
