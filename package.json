{
  "name": "@daemon-blockint/sync-core",
  "version": "0.1.0",
  "description": "Sync — Solana Mobile Seeker Anti-Virus detection engine (behavioral + signature + YARA + LLM pipeline).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx examples/demo.ts",
    "demo:llm": "tsx examples/llm-demo.ts",
    "serve": "tsx examples/serve.ts",
    "demo:intercept": "tsx examples/intercept-demo.ts",
    "demo:threatdb": "tsx examples/threatdb-demo.ts",
    "demo:ransomware": "tsx examples/ransomware-demo.ts"
  },
  "keywords": [
    "solana",
    "seeker",
    "anti-virus",
    "security",
    "yara",
    "wallet-drainer",
    "threat-detection"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^1.5.3",
    "zod": "^4.4.3"
  }
}
