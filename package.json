{
  "name": "@daemon-blockint/sync-core",
  "version": "0.1.0",
  "description": "Sync — Solana Mobile Seeker Anti-Virus detection engine (behavioral + signature + YARA + LLM pipeline).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx examples/demo.ts"
  },
  "keywords": [
    "solana",
    "seeker",
    "anti-virus",
    "security",
    "yara",
    "wallet-drainer",
    "threat-detection"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
